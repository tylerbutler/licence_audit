{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "type-enum": [
      2,
      "always",
      [
        "feat",
        "Feat",
        "FEAT",
        "fix",
        "Fix",
        "FIX",
        "docs",
        "Docs",
        "DOCS",
        "style",
        "Style",
        "STYLE",
        "refactor",
        "Refactor",
        "REFACTOR",
        "perf",
        "Perf",
        "PERF",
        "test",
        "Test",
        "TEST",
        "build",
        "Build",
        "BUILD",
        "ci",
        "Ci",
        "CI",
        "chore",
        "Chore",
        "CHORE",
        "revert",
        "Revert",
        "REVERT",
        "release",
        "Release",
        "RELEASE"
      ]
    ],
    "type-case": [0],
    "scope-case": [2, "always", "lower-case"],
    "subject-case": [0],
    "subject-empty": [2, "never"],
    "subject-full-stop": [2, "never", "."],
    "header-max-length": [2, "always", 72],
    "body-max-line-length": [2, "always", 100]
  }
}
