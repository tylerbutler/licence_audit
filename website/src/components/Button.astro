---
interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "ghost";
  size?: "md" | "lg";
  class?: string;
  rel?: string;
  [key: string]: unknown;
}
const {
  href,
  variant = "primary",
  size = "md",
  class: klass,
  rel,
  ...rest
} = Astro.props;
const Tag = href ? "a" : "button";
---

<Tag
  href={href}
  rel={rel}
  class:list={["btn", `btn--${variant}`, `btn--${size}`, klass]}
  {...rest}
>
  <slot />
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    border-radius: var(--r-full);
    border: 1px solid transparent;
    transition:
      transform var(--dur-fast) var(--ease-out-quart),
      box-shadow var(--dur) var(--ease-out-quart),
      background-color var(--dur-fast) var(--ease-out-quart),
      border-color var(--dur-fast) var(--ease-out-quart);
  }
  .btn:hover {
    text-decoration: none;
  }
  .btn--md {
    padding: 0.62rem 1.1rem;
    font-size: var(--fs-sm);
  }
  .btn--lg {
    padding: 0.85rem 1.5rem;
    font-size: var(--fs-body);
  }

  /* primary: pink field, dark ink (Gleam-flavoured, high legibility) */
  .btn--primary {
    background: var(--pink);
    color: oklch(0.2 0.02 335);
    box-shadow: 0 1px 0 oklch(1 0 0 / 0.35) inset,
      0 8px 20px -10px oklch(0.6 0.19 352 / 0.7);
  }
  .btn--primary:hover {
    background: var(--pink-hover);
    transform: translateY(-2px);
    box-shadow: 0 1px 0 oklch(1 0 0 / 0.35) inset,
      0 14px 26px -10px oklch(0.6 0.19 352 / 0.75);
  }
  .btn--primary:active {
    transform: translateY(0);
  }

  /* secondary: solid surface with hairline */
  .btn--secondary {
    background: var(--surface);
    color: var(--ink);
    border-color: var(--border-strong);
    box-shadow: var(--shadow-card);
  }
  .btn--secondary:hover {
    border-color: var(--pink);
    transform: translateY(-2px);
    color: var(--ink);
  }

  /* ghost: text-only with a quiet hover */
  .btn--ghost {
    background: transparent;
    color: var(--ink-2);
  }
  .btn--ghost:hover {
    color: var(--pink-link);
  }

  @media (prefers-reduced-motion: reduce) {
    .btn:hover {
      transform: none;
    }
  }
</style>
